{
  "identifier": "default",
  "description": "default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "store:default",
    "dialog:default",
    "fs:write-all",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "updater:default",
    "updater:allow-check",
    "process:allow-restart",
    "opener:default",
    "opener:allow-open-url",
    "core:window:default",
    "core:window:allow-start-dragging"
  ]
}
